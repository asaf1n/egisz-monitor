# ============================================================================
# EGISZ-Monitor Environment Configuration
# ============================================================================

# ========================================================================
# Image Versioning
# ========================================================================
REGISTRY=localhost:5000
BACKEND_VERSION=1.1.0
FRONTEND_VERSION=1.1.0
BUILD_DATE=2026-04-21T06:52:00Z
COMMIT_SHA=a1b2c3d4

# ========================================================================
# PostgreSQL Database
# ========================================================================
DB_NAME=egisz_monitor
DB_USER=egisz
DB_PASSWORD=egisz
DB_PORT=5432
PGDATA_PATH=./data/postgres

# ========================================================================
# Backend Application
# ========================================================================
NODE_ENV=production
LOG_LEVEL=info
BACKEND_PORT=3000

# Firebird Connection
FIREBIRD_HOST=host.docker.internal
FIREBIRD_PORT=3050
FIREBIRD_ALIAS=proxy_egisz
FIREBIRD_USER=sysdba
FIREBIRD_PASSWORD=masterkey
FIREBIRD_PAGE_SIZE=4096

# Database Schema
POSTGRES_SCHEMA=public

# ========================================================================
# Frontend Application
# ========================================================================
FRONTEND_PORT=8812
VITE_API_BASE_URL=http://localhost/api

# ========================================================================
# Metabase Analytics
# ========================================================================
METABASE_PORT=3001
MB_DB_NAME=metabase
MB_DB_USER=metabase
MB_DB_PASS=metabase
MB_ADMIN_EMAIL=admin@egisz-monitor.local
MB_ADMIN_PASSWORD=changeme
