{
  "name": "Технические метрики: НСИ и логи",
  "description": "Расширенный техконтур: карта здоровья, анализ НСИ и нормализованный журнал ошибок.",
  "collection_id": null,
  "cards": [
    {
      "name": "Карта здоровья (Heatmap)",
      "description": "Ошибки связи по JID в почасовом разрезе за 7 дней.",
      "table_ref": "v_unified_analytics",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT date_trunc('hour', ua.transaction_date) AS \"Hour\", ua.jid AS \"JID\", COUNT(*)::bigint AS \"Network errors\" FROM public.v_unified_analytics ua WHERE ua.is_error AND (ua.error_category = 'Infrastructure' OR ua.error_subcategory IN ('timeout', 'connection_refused', 'proxy')) AND ua.jid IS NOT NULL AND ua.transaction_date >= NOW() - INTERVAL '7 days' [[ AND ua.clinic_jid = {{clinic_jid}} ]] [[ AND ua.mo_uid = {{organization_oid}} ]] GROUP BY 1, 2 ORDER BY 1, 2;",
          "template-tags": {
            "clinic_jid": {
              "id": "clinic_jid",
              "name": "clinic_jid",
              "display-name": "Client ID (JID)",
              "type": "number",
              "required": false
            },
            "organization_oid": {
              "id": "organization_oid",
              "name": "organization_oid",
              "display-name": "Organization OID (Federal)",
              "type": "text",
              "required": false
            }
          }
        },
        "database": 1
      },
      "display": "heatmap",
      "visualization_settings": {
        "column_settings": {
          "[\"name\",\"clinic_id\"]": {
            "display_as": null
          },
          "[\"name\",\"clinic_jid\"]": {
            "display_as": null
          },
          "[\"name\",\"jid\"]": {
            "display_as": null
          },
          "[\"name\",\"mo_uid\"]": {
            "display_as": null
          },
          "[\"name\",\"original_LOGID\"]": {
            "display_as": null
          },
          "[\"name\",\"original_log_id\"]": {
            "display_as": null
          },
          "[\"name\",\"service_id\"]": {
            "display_as": null
          },
          "[\"name\",\"transaction_id\"]": {
            "display_as": null
          },
          "[\"name\",\"local_uid\"]": {
            "type": "text",
            "display_as": null
          }
        }
      },
      "sizeX": 12,
      "sizeY": 4,
      "row": 0,
      "col": 0
    },
    {
      "name": "Анализ НСИ",
      "description": "KIND, по которым чаще встречаются ошибки заполнения реквизитов/НСИ.",
      "table_ref": "v_unified_analytics",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT COALESCE(NULLIF(TRIM(ua.document_kind), ''), NULLIF(TRIM(ua.service_kind), ''), 'N/A') AS \"KIND\", COUNT(*)::bigint AS \"Validation/NSI errors\" FROM public.v_unified_analytics ua WHERE ua.is_error AND ua.error_subcategory = 'validation' AND ua.transaction_date >= NOW() - INTERVAL '30 days' [[ AND ua.clinic_jid = {{clinic_jid}} ]] [[ AND ua.mo_uid = {{organization_oid}} ]] GROUP BY 1 ORDER BY \"Validation/NSI errors\" DESC;",
          "template-tags": {
            "clinic_jid": {
              "id": "clinic_jid",
              "name": "clinic_jid",
              "display-name": "Client ID (JID)",
              "type": "number",
              "required": false
            },
            "organization_oid": {
              "id": "organization_oid",
              "name": "organization_oid",
              "display-name": "Organization OID (Federal)",
              "type": "text",
              "required": false
            }
          }
        },
        "database": 1
      },
      "display": "bar",
      "visualization_settings": {
        "graph.dimensions": [
          "KIND"
        ],
        "graph.metrics": [
          "Ошибки НСИ"
