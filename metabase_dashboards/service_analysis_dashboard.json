    {
      "name": "Node Stability by reply_to",
      "description": "Network incidents grouped by external clinic address.",
      "table_ref": "v_unified_analytics",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT COALESCE(NULLIF(TRIM(ua.reply_to), ''), '[no_reply_to]') AS \"reply_to\", COUNT(*)::bigint AS \"Network incidents\", COUNT(DISTINCT ua.clinic_jid)::bigint AS \"Clinics\", MAX(ua.transaction_date) AS \"Last incident\" FROM public.v_unified_analytics ua WHERE ua.is_error AND (ua.error_category = 'Infrastructure' OR ua.error_subcategory IN ('timeout', 'connection_refused', 'proxy')) AND ua.transaction_date >= NOW() - INTERVAL '30 days' [[ AND ua.clinic_jid = {{clinic_jid}} ]] [[ AND ua.mo_uid = {{organization_oid}} ]] GROUP BY 1 ORDER BY \"Network incidents\" DESC, \"reply_to\" ASC LIMIT 50;",
          "template-tags": {
            "clinic_jid": {
              "id": "clinic_jid",
              "name": "clinic_jid",
              "display-name": "Client ID (JID)",
