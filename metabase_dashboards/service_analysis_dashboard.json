    {
      "name": "Нормализованный лог",
      "description": "Список ошибок, очищенный от host/IP/динамических ID, для передачи в разработку.",
      "table_ref": "v_unified_analytics",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT ua.clean_error_text AS \"clean_error_text\", ua.error_category AS \"category\", COUNT(*)::bigint AS \"frequency\", COUNT(DISTINCT ua.jid)::bigint AS \"clinics\", MAX(ua.transaction_date) AS \"last_incident\" FROM public.v_unified_analytics ua WHERE ua.is_error AND ua.transaction_date >= NOW() - INTERVAL '30 days' [[ AND ua.clinic_jid = {{clinic_jid}} ]] [[ AND ua.mo_uid = {{organization_oid}} ]] GROUP BY ua.clean_error_text, ua.error_category ORDER BY \"frequency\" DESC LIMIT 100;",
          "template-tags": {
            "clinic_jid": {
              "id": "clinic_jid",
              "name": "clinic_jid",
              "display-name": "Client ID (JID)",
              "type": "number",
              "required": false
            },
            "organization_oid": {
              "id": "organization_oid",
              "name": "organization_oid",
              "display-name": "Organization OID (Federal)",
              "type": "text",
              "required": false
            }
          }
        },
        "database": 1
      },
