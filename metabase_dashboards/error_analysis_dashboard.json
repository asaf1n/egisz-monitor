{
    "name":  "Технический анализ",
    "description":  "Технический мониторинг EGISZ: матрица ошибок, heatmap доступности и топ структурированных инцидентов.",
    "collection_id":  null,
    "cards":  [
                  {
                      "name":  "Матрица ошибок",
                      "description":  "Pivot-матрица KIND x error_category за 30 дней.",
                      "dataset_query":  {
                                            "type":  "native",
                                            "native":  {
                                                           "query":  "SELECT COALESCE(NULLIF(TRIM(ua.document_type), \u0027\u0027), NULLIF(TRIM(ua.service_kind), \u0027\u0027), \u0027Не указан\u0027) AS \"KIND\", COALESCE(NULLIF(TRIM(ua.error_category), \u0027\u0027), \u0027Прочие ошибки\u0027) AS \"Категория ошибки\", COUNT(*)::bigint AS \"Количество\" FROM public.v_unified_analytics ua WHERE ua.is_error AND ua.transaction_date \u003e= NOW() - INTERVAL \u002730 days\u0027 GROUP BY 1, 2 ORDER BY 1 ASC, 3 DESC;"
                                                       },
                                            "database":  1
                                        },
                      "display":  "table",
                      "visualization_settings":  {
                                                     "table.pivot_column":  "Категория ошибки",
                                                     "table.cell_column":  "Количество"
                                                 },
                      "sizeX":  12,
                      "sizeY":  4,
                      "row":  0,
                      "col":  0
                  },
                  {
                      "name":  "Heatmap доступности",
                      "description":  "Почасовая плотность ошибок по клиникам за 7 дней.",
                      "dataset_query":  {
                                            "type":  "native",
                                            "native":  {
                                                           "query":  "SELECT date_trunc(\u0027hour\u0027, ua.transaction_date) AS \"Час\", ua.clinic_label AS \"Клиника\", COUNT(*) FILTER (WHERE ua.is_error)::bigint AS \"Ошибки\" FROM public.v_unified_analytics ua WHERE ua.clinic_jid IS NOT NULL AND ua.transaction_date \u003e= NOW() - INTERVAL \u00277 days\u0027 [[ AND ua.clinic_jid = {{clinic_jid}} ]] GROUP BY 1, 2 ORDER BY 1 ASC, 2 ASC;",
                                                           "template-tags":  {
                                                                                 "clinic_jid":  {
                                                                                                    "id":  "clinic_jid",
                                                                                                    "name":  "clinic_jid",
                                                                                                    "display-name":  "JID клиники",
                                                                                                    "type":  "number",
                                                                                                    "required":  false
                                                                                                }
                                                                             }
                                                       },
                                            "database":  1
                                        },
                      "display":  "heatmap",
                      "visualization_settings":  {
                                                     "graph.dimensions":  [
                                                                              "Час",
                                                                              "Клиника"
                                                                          ],
                                                     "graph.metrics":  [
                                                                           "Ошибки"
                                                                       ]
                                                 },
                      "sizeX":  12,
                      "sizeY":  4,
                      "row":  0,
                      "col":  12
                  },
                  {
                      "name":  "Топ-20 ошибок ЕГИЗС",
                      "description":  "Таблица ошибок по структурированным полям error_code и error_message.",
                      "dataset_query":  {
                                            "type":  "native",
                                            "native":  {
                                                           "query":  "SELECT ua.clinic_label AS \"clinic_label\", COALESCE(NULLIF(TRIM(ua.error_code), \u0027\u0027), \u0027[no_code]\u0027) AS \"error_code\", COALESCE(NULLIF(TRIM(ua.error_message), \u0027\u0027), \u0027[no_message]\u0027) AS \"error_message\", COUNT(*)::bigint AS \"count\" FROM public.v_unified_analytics ua WHERE ua.is_error AND ua.transaction_date \u003e= NOW() - INTERVAL \u002730 days\u0027 [[ AND ua.clinic_jid = {{clinic_jid}} ]] GROUP BY ua.clinic_label, COALESCE(NULLIF(TRIM(ua.error_code), \u0027\u0027), \u0027[no_code]\u0027), COALESCE(NULLIF(TRIM(ua.error_message), \u0027\u0027), \u0027[no_message]\u0027) ORDER BY \"count\" DESC, \"clinic_label\" ASC LIMIT 20;",
                                                           "template-tags":  {
                                                                                 "clinic_jid":  {
                                                                                                    "id":  "clinic_jid",
                                                                                                    "name":  "clinic_jid",
                                                                                                    "display-name":  "JID клиники",
                                                                                                    "type":  "number",
                                                                                                    "required":  false
                                                                                                }
                                                                             }
                                                       },
                                            "database":  1
                                        },
                      "display":  "table",
                      "visualization_settings":  {
                                                     "column_settings":  {
                                                                             "[\"name\",\"clinic_id\"]":  {
                                                                                                              "display_as":  null
                                                                                                          },
                                                                             "[\"name\",\"clinic_jid\"]":  {
                                                                                                               "display_as":  null
                                                                                                           }
                                                                         }
                                                 },
                      "sizeX":  24,
                      "sizeY":  5,
                      "row":  4,
                      "col":  0
                  }
              ],
    "parameters":  [
                       {
                           "id":  "clinic_jid_filter",
                           "name":  "JID клиники",
                           "slug":  "clinic_jid_filter",
                           "type":  "number"
                       }
                   ]
}
