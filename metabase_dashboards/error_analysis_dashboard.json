    {
      "name": "Доступность по reply_to",
      "description": "Сетевые инциденты, сгруппированные по внешнему адресу медицинской организации.",
      "table_ref": "v_unified_analytics",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT COALESCE(NULLIF(TRIM(ua.reply_to), ''), '[без reply_to]') AS \"reply_to\", COUNT(*)::bigint AS \"Инциденты\", COUNT(DISTINCT ua.clinic_jid)::bigint AS \"Клиники\", MAX(ua.transaction_date) AS \"Последний инцидент\" FROM public.v_unified_analytics ua WHERE ua.is_error AND (ua.error_category = 'Ошибка связи' OR ua.error_subcategory IN ('timeout', 'connection_refused', 'proxy')) AND ua.transaction_date >= NOW() - INTERVAL '30 days' [[ AND ua.clinic_jid = {{clinic_jid}} ]] [[ AND ua.mo_uid = {{organization_oid}} ]] [[ AND ua.local_uid ILIKE CONCAT('%', {{local_uid}}, '%') ]] GROUP BY 1 ORDER BY \"Инциденты\" DESC, \"reply_to\" ASC LIMIT 50;",
          "template-tags": {
