    {
      "name": "Heatmap доступности",
      "description": "Почасовая плотность ошибок по клиникам за 7 дней.",
      "table_ref": "v_unified_analytics",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT date_trunc('hour', ua.transaction_date) AS \"Hour\", ua.clinic_label AS \"Clinic\", COUNT(*) FILTER (WHERE ua.is_error)::bigint AS \"Errors\" FROM public.v_unified_analytics ua WHERE ua.clinic_jid IS NOT NULL AND ua.transaction_date >= NOW() - INTERVAL '7 days' [[ AND ua.clinic_jid = {{clinic_jid}} ]] [[ AND ua.mo_uid = {{organization_oid}} ]] [[ AND ua.local_uid ILIKE CONCAT('%', {{local_uid}}, '%') ]] GROUP BY 1, 2 ORDER BY 1 ASC, 2 ASC;",
          "template-tags": {
            "clinic_jid": {
              "id": "clinic_jid",
              "name": "clinic_jid",
              "display-name": "Client ID (JID)",
