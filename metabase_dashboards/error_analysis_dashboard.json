{
  "name": "Анализ ошибок",
  "description": "Технический и поддерживающий контур: ошибки по типам документов, Heatmap доступности и повторяющиеся инциденты.",
  "collection_id": null,
  "cards": [
    {
      "name": "Матрица: тип документа vs ошибка",
      "description": "Сводная матрица по типам документов и категориям ошибок за 30 дней.",
      "table_ref": "v_unified_analytics",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT COALESCE(NULLIF(TRIM(ua.document_kind), ''), NULLIF(TRIM(ua.service_kind), ''), 'Не указан') AS \"Тип документа\", COALESCE(NULLIF(TRIM(ua.error_category), ''), 'Прочие ошибки') AS \"Ошибка\", COUNT(*)::bigint AS \"Количество\" FROM public.v_unified_analytics ua WHERE ua.is_error AND ua.transaction_date >= NOW() - INTERVAL '30 days' [[ AND ua.clinic_jid = {{clinic_jid}} ]] [[ AND ua.mo_uid = {{organization_oid}} ]] [[ AND ua.local_uid ILIKE CONCAT('%', {{local_uid}}, '%') ]] GROUP BY 1, 2 ORDER BY 1 ASC, 3 DESC;",
          "template-tags": {
            "clinic_jid": {
              "id": "clinic_jid",
              "name": "clinic_jid",
              "display-name": "Client ID (JID)",
              "type": "number",
              "required": false
            },
            "organization_oid": {
              "id": "organization_oid",
              "name": "organization_oid",
              "display-name": "Organization OID (Federal)",
              "type": "text",
              "required": false
            },
            "local_uid": {
              "id": "local_uid",
              "name": "local_uid",
              "display-name": "LocalUID",
              "type": "text",
              "required": false
            }
          }
        },
        "database": 1
      },
      "display": "table",
      "visualization_settings": {
        "table.pivot_column": "Ошибка",
        "table.cell_column": "Количество",
        "column_settings": {
          "[\"name\",\"clinic_id\"]": {
            "display_as": null
          },
          "[\"name\",\"clinic_jid\"]": {
            "display_as": null
          },
          "[\"name\",\"jid\"]": {
