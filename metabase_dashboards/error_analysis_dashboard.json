              "required": false
            },
            "local_uid": {
              "id": "local_uid",
              "name": "local_uid",
              "display-name": "LocalUID",
              "type": "text",
              "required": false
            }
          }
        },
        "database": 1
      },
      "display": "heatmap",
      "visualization_settings": {
        "graph.dimensions": [
          "Hour",
