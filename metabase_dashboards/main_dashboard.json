{
  "name": "Дашборд сервиса интеграции",
  "description": "Основные показатели сервиса интеграции: охват, успешность по типам документов и динамика по медицинским организациям.",
  "collection_id": null,
  "cards": [
    {
      "name": "Охват сервиса",
      "description": "Доля активных клиник за 30 дней от общего количества зарегистрированных JID.",
      "table_ref": "v_unified_analytics",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "WITH total AS (SELECT COUNT(DISTINCT dc.jid)::numeric AS total_registered FROM public.dim_clinics dc WHERE dc.jid IS NOT NULL AND dc.mo_uid <> 'ghost-log-group-9901'), active AS (SELECT COUNT(DISTINCT ua.jid)::numeric AS active_30d FROM public.v_unified_analytics ua WHERE ua.jid IS NOT NULL AND ua.transaction_date >= NOW() - INTERVAL '30 days' [[ AND ua.clinic_jid = {{clinic_jid}} ]] [[ AND ua.mo_uid = {{organization_oid}} ]]) SELECT total.total_registered::bigint AS \"Всего клиник\", active.active_30d::bigint AS \"Активные клиники\", COALESCE(ROUND(100.0 * active.active_30d / NULLIF(total.total_registered, 0), 2), 0) AS \"Охват сервиса, %\" FROM total CROSS JOIN active;",
          "template-tags": {
            "clinic_jid": {
              "id": "clinic_jid",
              "name": "clinic_jid",
              "display-name": "Client ID (JID)",
              "type": "number",
              "required": false
            },
            "organization_oid": {
              "id": "organization_oid",
              "name": "organization_oid",
              "display-name": "Organization OID (Federal)",
              "type": "text",
              "required": false
            }
          }
        },
        "database": 1
      },
      "display": "gauge",
      "visualization_settings": {
        "graph.metric": "Охват сервиса, %",
        "column_settings": {
          "[\"name\",\"clinic_id\"]": {
            "display_as": null
          },
          "[\"name\",\"clinic_jid\"]": {
            "display_as": null
          },
          "[\"name\",\"jid\"]": {
            "display_as": null
          },
          "[\"name\",\"mo_uid\"]": {
            "display_as": null
          },
          "[\"name\",\"original_LOGID\"]": {
            "display_as": null
          },
          "[\"name\",\"original_log_id\"]": {
            "display_as": null
          },
          "[\"name\",\"service_id\"]": {
            "display_as": null
          },
          "[\"name\",\"transaction_id\"]": {
            "display_as": null
          },
          "[\"name\",\"local_uid\"]": {
            "type": "text",
            "display_as": null
          }
        }
      },
      "sizeX": 8,
      "sizeY": 3,
      "row": 0,
      "col": 0
    },
    {
      "name": "Успешность по типам СЭМД",
      "description": "Доля успешных отправок по кодам KIND за 30 дней.",
      "table_ref": "v_unified_analytics",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT COALESCE(NULLIF(TRIM(ua.document_kind), ''), NULLIF(TRIM(ua.service_kind), ''), 'Не указан') AS \"Тип СЭМД\", COUNT(*)::bigint AS \"Всего\", COUNT(*) FILTER (WHERE ua.is_success)::bigint AS \"Успешно\", COUNT(*) FILTER (WHERE ua.is_error)::bigint AS \"Ошибки\", COALESCE(ROUND(100.0 * COUNT(*) FILTER (WHERE ua.is_success) / NULLIF(COUNT(*), 0), 2), 0) AS \"Успешность, %\" FROM public.v_unified_analytics ua WHERE ua.transaction_date >= NOW() - INTERVAL '30 days' [[ AND ua.clinic_jid = {{clinic_jid}} ]] [[ AND ua.mo_uid = {{organization_oid}} ]] GROUP BY 1 ORDER BY \"Успешность, %\" ASC, \"Всего\" DESC;",
          "template-tags": {
            "clinic_jid": {
              "id": "clinic_jid",
              "name": "clinic_jid",
              "display-name": "Client ID (JID)",
              "type": "number",
              "required": false
            },
            "organization_oid": {
              "id": "organization_oid",
              "name": "organization_oid",
              "display-name": "Organization OID (Federal)",
              "type": "text",
              "required": false
            }
          }
        },
        "database": 1
      },
      "display": "bar",
      "visualization_settings": {
        "graph.dimensions": [
          "Тип СЭМД"
        ],
        "graph.metrics": [
          "Успешность, %"
        ],
        "column_settings": {
