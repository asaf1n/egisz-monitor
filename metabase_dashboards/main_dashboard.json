    {
      "name": "Динамика по медицинским организациям",
      "description": "Топ активных клиник по объему транзакций за последние 30 дней.",
      "table_ref": "v_unified_analytics",
      "dataset_query": {
        "type": "native",
        "native": {
          "query": "SELECT ua.clinic_label AS \"Клиника\", COUNT(*)::bigint AS \"Транзакции\", COUNT(*) FILTER (WHERE ua.is_success)::bigint AS \"Успешно\", COUNT(*) FILTER (WHERE ua.is_error)::bigint AS \"Ошибки\" FROM public.v_unified_analytics ua WHERE ua.clinic_jid IS NOT NULL AND ua.transaction_date >= NOW() - INTERVAL '30 days' [[ AND ua.clinic_jid = {{clinic_jid}} ]] [[ AND ua.mo_uid = {{organization_oid}} ]] GROUP BY ua.clinic_label ORDER BY \"Транзакции\" DESC, ua.clinic_label ASC LIMIT 30;",
          "template-tags": {
            "clinic_jid": {
